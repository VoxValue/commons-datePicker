{
    "name": "react-tailwindcss-datepicker",
    "version": "2.0.0",
    "description": "A modern React Datepicker using Tailwind CSS 3",
    "type": "module",
    "module": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            }
        }
    },
    "author": "onesine",
    "license": "MIT",
    "scripts": {
        "watch": "tsdown --watch",
        "clean": "rm -rf dist",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "pret:fix": "prettier --write .",
        "format": "npm run pret:fix && npm run lint:fix",
        "build": "npm run lint && npm run clean && tsdown",
        "pub": "npm run build && np --no-tests",
        "dev": "next dev -p 8888"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/onesine/react-tailwindcss-datepicker"
    },
    "keywords": [
        "react-tailwindcss-datepicker",
        "react-datepicker",
        "tailwind-datepicker",
        "datepicker",
        "date-picker",
        "daterangepicker",
        "react-daterangepicker",
        "date-range",
        "date-range-picker",
        "tailwind-daterange-picker"
    ],
    "peerDependencies": {
        "dayjs": "^1.11.12",
        "react": "^17.0.2 || ^18.2.0 || ^19.0.0"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.7",
        "@types/node": "^22.3.0",
        "@types/react": "^19.0.8",
        "@typescript-eslint/eslint-plugin": "^8.22.0",
        "@typescript-eslint/parser": "^8.22.0",
        "autoprefixer": "^10.4.20",
        "dayjs": "^1.11.12",
        "eslint": "^8.57.0",
        "eslint-config-next": "^15.1.6",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-react": "^7.35.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.18",
        "next": "^15.1.6",
        "postcss": "^8.4.41",
        "prettier": "^3.3.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^3.4.10",
        "tsdown": "^0.22.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3"
    },
    "files": [
        "dist"
    ]
}
